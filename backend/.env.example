GEMINI_API_KEY=your_gemini_api_key_here
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
PORT=8080
GEMINI_MODEL=gemini-3.5-flash
CLEANER_GEMINI_MODEL=gemini-3.1-flash-lite

# Ingestion Features Toggle
ENABLE_OBSIDIAN_INBOX_POLLING=false
ENABLE_TELEGRAM_BOT=true
ENABLE_GMAIL_POLLING=true

# Telegram Bot configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_CHAT_IDS=comma_separated_allowed_chat_ids_here

# Gmail IMAP configuration
GMAIL_EMAIL=stevenmeers@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here
